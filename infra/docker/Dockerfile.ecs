FROM alibaba-cloud-linux-3-registry.cn-hangzhou.cr.aliyuncs.com/alinux3/alinux3:latest AS base
RUN dnf install -y curl tar gzip && dnf clean all
COPY aigon-agent-qwen-society /usr/local/bin/
COPY standalone.yaml /opt/aigon-hack/config.yaml
EXPOSE 7000
ENV QWEN_API_KEY="sk-your-qwen-api-key-here"
ENV QWEN_ENDPOINT="https://<your-workspace-id>.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1"
ENV QWEN_MODEL="qwen3.7-max"
CMD ["aigon-agent-qwen-society", "--mode", "standalone", "--config", "/opt/aigon-hack/config.yaml"]
